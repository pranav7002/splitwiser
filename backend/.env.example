# MongoDB connection URI (use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net

# Server port (Render/Railway set this automatically)
PORT=8000

# CORS allowed origin (set to your frontend URL in production)
CORS_ORIGIN=*

# zkVM proving service URL
ZKVM_SERVICE_URL=http://localhost:3002
ZKVM_TIMEOUT_MS=300000

# AA Execution Service URL
EXECUTION_SERVICE_URL=http://localhost:3001/execute-settlement
