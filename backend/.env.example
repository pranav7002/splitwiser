# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017

# Server port
PORT=8000

# CORS allowed origin (use * for development)
CORS_ORIGIN=*

# zkVM configuration (absolute path to the compiled Risc0 host binary)
ZKVM_COMMAND=/path/to/settlement-zkvm/target/release/host
ZKVM_TIMEOUT_MS=300000

# Blockchain / AA configuration
CHAIN_RPC_URL=
ENTRYPOINT_ADDRESS=
BUNDLER_URL=
PAYMASTER_URL=
CONTRACT_ADDRESS=

# Signer (use for development only, never commit real keys)
PRIVATE_KEY=
