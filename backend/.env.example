# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017

# Server port
PORT=8000

# CORS allowed origin (use * for development)
CORS_ORIGIN=*

# zkVM configuration (absolute path to the compiled Risc0 host binary)
ZKVM_COMMAND=/path/to/settlement-zkvm/target/release/host
ZKVM_TIMEOUT_MS=300000

# Blockchain / AA configuration
CHAIN_RPC_URL=
EXECUTION_SERVICE_URL=http://localhost:3001/execute-settlement
CONTRACT_ADDRESS=0x5E1c657AE35e5EB006ECfA69Fa1e1aC3Ef415716
