# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017

# Server port
PORT=8000

# CORS allowed origin (use * for development)
CORS_ORIGIN=*

# zkVM configuration
ZKVM_COMMAND=
ZKVM_ARGS=
ZKVM_ARGS_JSON=
ZKVM_TIMEOUT_MS=120000

# Blockchain / AA configuration
CHAIN_RPC_URL=
ENTRYPOINT_ADDRESS=
BUNDLER_URL=
PAYMASTER_URL=
CONTRACT_ADDRESS=

# Signer (use for development only, never commit real keys)
PRIVATE_KEY=
