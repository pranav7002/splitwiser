# Sepolia RPC endpoint (Alchemy, Infura, etc.)
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Pimlico Bundler + Paymaster URL
BUNDLER_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=YOUR_KEY

# Agent's private key (signs UserOperations)
AGENT_PRIVATE_KEY=0x...

# On-chain SplitWise group contract address
GROUP_ADDRESS=0x...

# Server port (Render/Railway set this automatically)
PORT=3001
